# Supabase Configuration
# Project URL - MUST start with https:// (find in Supabase: Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# Anon public key (find in Supabase: Settings → API → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Resend (for sending invoices by email - optional)
# Get key at https://resend.com | Use onboarding@resend.dev for testing
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev

# App Configuration
# For production: use your deployed app URL (e.g. https://your-app.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000
